{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Diverging bar (population-pyramid style) comparing male vs. female rates of smoking and lung cancer. Men sit higher on both measures, and the gap is far wider for lung cancer than for smoking, reflecting decades of accumulated exposure. Value labels are placed inside each bar so they stay readable on the coloured marks. Data: data/by_gender.csv (sex, metric, value).",
  "title": {
    "text": "Men still smoke more, and get more lung cancer",
    "subtitle": [
      "Daily smoking rate (%) and lung cancer incidence (per 100,000).",
      "Men's lung cancer risk is about 32% higher than women's."
    ]
  },
  "width": "container",
  "height": 240,
  "data": { "url": "data/by_gender.csv" },
  "transform": [
    { "calculate": "datum.sex == 'Male' ? -datum.value : datum.value", "as": "signed_value" }
  ],
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 2 },
      "encoding": {
        "y": {
          "field": "metric", "type": "nominal",
          "axis": { "title": null, "labelAngle": 0, "labelLimit": 200 }
        },
        "x": {
          "field": "signed_value", "type": "quantitative",
          "scale": { "domain": [-70, 55] },
          "axis": { "title": "Male                                        Female", "format": ".0f", "labelExpr": "abs(datum.value)" }
        },
        "color": {
          "field": "sex", "type": "nominal",
          "scale": { "domain": ["Male", "Female"], "range": ["#1f3a5f", "#c0392b"] },
          "legend": { "title": null, "orient": "top" }
        },
        "tooltip": [
          { "field": "sex",    "type": "nominal", "title": "Sex" },
          { "field": "metric", "type": "nominal", "title": "Measure" },
          { "field": "value",  "type": "quantitative", "title": "Value", "format": ".1f" }
        ]
      }
    },
    {
      "transform": [ { "filter": "datum.sex == 'Male'" } ],
      "mark": { "type": "text", "align": "left", "dx": 4, "fontSize": 11, "fontWeight": 600, "color": "#ffffff" },
      "encoding": {
        "y": { "field": "metric", "type": "nominal" },
        "x": { "field": "signed_value", "type": "quantitative" },
        "text": { "field": "value", "type": "quantitative", "format": ".1f" }
      }
    },
    {
      "transform": [ { "filter": "datum.sex == 'Female'" } ],
      "mark": { "type": "text", "align": "right", "dx": -4, "fontSize": 11, "fontWeight": 600, "color": "#ffffff" },
      "encoding": {
        "y": { "field": "metric", "type": "nominal" },
        "x": { "field": "signed_value", "type": "quantitative" },
        "text": { "field": "value", "type": "quantitative", "format": ".1f" }
      }
    }
  ]
}
